{
  "mcpServers": {
    "excalidraw": {
      "command": "npx",
      "args": ["-y", "@excalidraw/mcp-server"],
      "description": "Generate and edit Excalidraw diagrams from natural language. No auth needed."
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/inventory"
      ],
      "description": "Query PostgreSQL — update the connection string to match your .env"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/inventory-optimization"
      ],
      "description": "Sandboxed file access — update path to your local repo root"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "Multi-step reasoning. No auth needed."
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "description": "Real-time library docs. Add 'use context7' to any prompt. No auth needed."
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "mcp-server-fetch"],
      "description": "Fetch any URL. No auth needed."
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT_HERE"
      },
      "description": "GitHub: create issues/PRs from specs. Needs a Personal Access Token."
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "YOUR_BRAVE_API_KEY_HERE"
      },
      "description": "Web search. Get free API key at https://brave.com/search/api/"
    }
  }
}
