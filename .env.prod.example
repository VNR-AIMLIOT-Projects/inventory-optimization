# Production Environment values template for DigitalOcean

# Service ports
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

# Application connection and security
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=inventory

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=CHANGE_ME_SECURE_PASSWORD

# Web configurations
CORS_ORIGINS=*
BACKEND_PUBLIC_URL=http://YOUR_DROPLET_IP:8000

# Worker tuning
WORKER_REPLICAS=1
GROQ_API_KEY=your_groq_api_key_here
