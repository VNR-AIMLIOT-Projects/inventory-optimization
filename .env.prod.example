# Copy this file to .env.prod and fill values before deployment.
# Example: cp .env.prod.example .env.prod

# Project / region
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
GCP_ZONE=asia-south1-a
VM_NAME=inventory-gpu-vm

# Machine sizing
MACHINE_TYPE=n1-standard-4
GPU_TYPE=nvidia-tesla-t4
GPU_COUNT=1
BOOT_DISK_SIZE_GB=100

# Service ports
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

# Application connection and security
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=inventory
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=change-me
CORS_ORIGINS=*
BACKEND_PUBLIC_URL=http://YOUR_VM_EXTERNAL_IP:8000

# Worker tuning
WORKER_REPLICAS=1

# Optional GCP network names
NETWORK=default
SUBNET=default
